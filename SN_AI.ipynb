   "source": [
    "# for every season i want to create a \"predicted\" ranking based on the predicted outcomes of the matches, and compare it to the actual ranking based on the true outcomes of the matches, and print the top 5 teams in both rankings for each season\n",
    "for season in sorted(set(m[\"season\"] for matches in test_matches.values() for m in matches)):\n",
    "    print(f\"\\nSeason {season} - Predicted vs Actual Rankings:\")\n",
    "\n",
    "    # group matches if they belong to the same season and exist, example: if the season 2526 does not have any Juventus-Venezia matches, it should not be included in the season_matches dictionary\n",
    "    season_matches = {}\n",
    "    for match_key, matches in test_matches.items():\n",
    "        season_matches[match_key] = [m for m in matches if m[\"season\"] == season]\n",
    "\n",
    "    # Calcola i punti per ogni squadra basandosi sulle predizioni\n",
    "    predicted_points = {team: 0 for team in all_possible_teams.keys()}\n",
    "    actual_points = {team: 0 for team in all_possible_teams.keys()}\n",
    "\n",
    "    for match_key, matches in season_matches.items():\n",
    "        home_team, away_team = match_key\n",
    "        for match in matches:\n",
    "            predicted_label = test_preds[test_matches[match_key].index(match)]\n",
    "            print(f\"Match: {home_team} vs {away_team}, Predicted label: {predicted_label}\")\n",
    "            true_label = test_targets[test_matches[match_key].index(match)]\n",
    "\n",
    "            # Aggiorna i punti basati sulla predizione\n",
    "            if predicted_label == 0:  # Home Win\n",
    "                predicted_points[home_team] += 3\n",
    "            elif predicted_label == 1:  # Draw\n",
    "                predicted_points[home_team] += 1\n",
    "                predicted_points[away_team] += 1\n",
    "            else:  # Away Win\n",
    "                predicted_points[away_team] += 3\n",
    "\n",
    "            # Aggiorna i punti basati sul risultato reale\n",
    "            if true_label == 0:  # Home Win\n",
    "                actual_points[home_team] += 3\n",
    "            elif true_label == 1:  # Draw\n",
    "                actual_points[home_team] += 1\n",
    "                actual_points[away_team] += 1\n",
    "            else:  # Away Win\n",
    "                actual_points[away_team] += 3\n",
    "\n",
    "    # Ordina le squadre per punti\n",
    "    predicted_ranking = sorted(predicted_points.items(), key=lambda x: x[1], reverse=True)\n",
    "    actual_ranking = sorted(actual_points.items(), key=lambda x: x[1], reverse=True)\n",
    "\n",
    "    # print side by side the top 5 teams in both rankings\n",
    "    print(f\"{'Predicted Ranking':<30} {'Actual Ranking':<30}\")\n",
    "    for i in range(5):\n",
    "        pred_team, pred_points = predicted_ranking[i]\n",
    "        actual_team, actual_points = actual_ranking[i]\n",
    "        print(f\"{pred_team} ({pred_points} pts) {'':<10} {actual_team} ({actual_points} pts)\")\n",
    "\n",
    "\n"
